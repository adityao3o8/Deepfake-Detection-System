# Local backend (default)
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Vercel / production — proxy browser calls to Render (recommended):
# BACKEND_INTERNAL_URL=https://deepfake-detection-system-2-2rgl.onrender.com
# Browser POSTs to /api/proxy/detect → Render /api/detect

# Optional: call backend directly from the browser (needs CORS on API):
# NEXT_PUBLIC_API_URL=https://deepfake-detection-system-2-2rgl.onrender.com
# Resolves to https://...onrender.com/api/detect
